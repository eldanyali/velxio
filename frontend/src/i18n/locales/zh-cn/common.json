  "footer": {
    "about": "Velxio 是一款免费开源的电路与微控制器模拟器，完全在浏览器中运行。支持 Arduino、ESP32、RP2040 和 ATtiny85，并具备 SPICE 精度的模拟协同仿真。专为动手实践的学习者、学生和嵌入式工程师打造。采用 AGPLv3 许可。"
  },
  "landing": {
    "hero": {
      "titleLine1": "Arduino、ESP32 和 Raspberry Pi。",
      "titleAccent": "就在你的浏览器中。",
      "subtitle": "编写代码、连接元件、点击运行。19 种开发板、48 多个部件、真实的 CPU 仿真——无需硬件、无需安装、无需云端。",
      "ctaPrimary": "免费试用模拟器 →",
      "ctaGithub": "在 GitHub 上查看",
      "trustLine": "无需注册 · 100% 在浏览器中运行 · 免费且开源",
      "imageAlt": "Velxio 编辑器中的 Arduino Uno 交通灯电路"
    },
    "boards": {
      "label": "支持的硬件",
      "titleLine1": "每一种架构。",
      "titleLine2": "一个工具。",
      "subtitle": "涵盖 5 种 CPU 架构的 19 种开发板——AVR8、ARM Cortex-M0+、RISC-V、Xtensa 和 Linux。全部本地运行，无需云端。"
    },
    "features": {
      "label": "功能特性",
      "title": "你需要的一切。",
      "subtitle": "一个完整的 IDE、编译器和多架构模拟器——本地运行，无需外部服务。",
      "spice": {
        "title": "实时 SPICE 模拟",
        "desc": "ngspice-WASM 引擎——以约 60 Hz 频率执行完整的改进节点分析。电阻、电容、运放、BJT、MOSFET、稳压器表现如同真实硅器件，而非理想化模型。"
      },
      "engines": {
        "title": "5 种仿真引擎",
        "desc": "AVR8（ATmega328P、ATmega2560、ATtiny85）、RP2040（ARM Cortex-M0+）、RV32IMC（ESP32-C3、CH32V003 通过 QEMU）、Xtensa LX6/LX7（ESP32 通过 QEMU）以及 ARM Cortex-A53（Raspberry Pi 3 Linux）。"
      },
      "customChips": {
        "title": "自定义芯片",
        "desc": "使用 Wokwi 自定义芯片 API，用 C、Rust 或 AssemblyScript 编写你自己的集成电路。编译为 WebAssembly 并在项目间复用。"
      },
      "components": {
        "title": "100 多个元件",
        "desc": "SPICE 精度的模拟元件加上 48 多个 wokwi 可视化元件——LED、LCD、ILI9341 TFT、舵机、蜂鸣器、超声波传感器、键盘、NeoPixel 灯带。"
      },
      "instruments": {
        "title": "实时仪器",
        "desc": "多通道示波器、电压表、电流表、信号发生器。拖放到任意节点，在仿真运行时实时观察波形更新。"
      },
      "monaco": {
        "title": "Monaco 编辑器 + arduino-cli",
        "desc": "VS Code 级别的 C++ 编辑器，支持多文件工作区。本地的 arduino-cli 编译生成真实的 .hex / .uf2 / .bin 文件——无需云端往返。"
      }
    },
    "support": {
